{
  "name": "tipsy",
  "version": "2.2.0",
  "private": true,
  "description": "A simple tip calculator and bill divider PWA",
  "bugs": {
    "url": "https://github.com/wKovacs64/tipsy/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin Hall",
    "email": "justin.r.hall@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wKovacs64/tipsy.git"
  },
  "type": "module",
  "imports": {
    "#/*": "./*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "preview": "vite --host 127.0.0.1 preview",
    "test": "pnpm run test:e2e:open",
    "test:e2e:open": "playwright test --ui",
    "test:e2e:run": "cross-env CI=true playwright test",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@fontsource/source-sans-3": "5.2.9",
    "clsx": "2.1.1",
    "currency.js": "2.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.15.0",
    "tailwindcss": "4.2.4",
    "use-local-storage-state": "19.5.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-syntax-jsx": "7.28.6",
    "@playwright/test": "1.59.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.2.4",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@wkovacs64/add-icon": "1.2.2",
    "@wkovacs64/eslint-config": "7.14.0",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "fs-extra": "11.3.5",
    "git-current-commit": "1.1.0",
    "oxfmt": "0.48.0",
    "type-fest": "5.6.0",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vite-plugin-icons-spritesheet": "3.0.1",
    "vite-plugin-pwa": "1.3.0",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  },
  "packageManager": "pnpm@10.33.4"
}
